# ====================================
# SPORTS AI — Environment Configuration
# ====================================

# Statpal Soccer API (https://statpal.io/docs/)
STATPAL_ACCESS_KEY=your_statpal_access_key_here
STATPAL_BASE_URL=https://statpal.io/api/v2
STATPAL_SPORT=soccer

# Legacy API-Football fallback (optional)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# LLM Configuration
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://sports_ai:password@localhost:5432/sports_ai

# Redis
REDIS_URL=redis://localhost:6379

# Application
APP_ENV=development
APP_PORT=8000
MODEL_PATH=./artifacts/models
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000
ADMIN_TOKEN_TTL_SECONDS=43200

# Admin (required in production)
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
